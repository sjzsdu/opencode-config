{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "/Users/juzhongsun/Codes/ts/OpencodePlugins/plugins/emperor",
    "opencode-google-antigravity-auth",
    "opencode-supermemory",
    "opencode-scheduler",
  ],
  "theme": "opencode",
  "model": "opencode/minimax-m2.5-free", 
  "autoupdate": true,
  "mcp": {
    "git-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/git-mcp-server@latest"],
      "enabled": true,
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "wireshark": {
      "command": "uv",
      "args": ["tool", "run", "wireshark-mcp"]
    }
  }
}